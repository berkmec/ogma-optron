# HuggingFace Inference Providers (OpenAI-compatible router)
# Get token at: https://huggingface.co/settings/tokens (Read access is enough)
HF_TOKEN=hf_your_token_here

# Vision model used for image understanding, planning, and reporting
VISION_MODEL=Qwen/Qwen3-VL-8B-Instruct

# HF router base URL (OpenAI-compatible)
OPENAI_BASE_URL=https://router.huggingface.co/v1

# Backend
APP_HOST=127.0.0.1
APP_PORT=8000

# Path to agent-code (claw upstream) binary. Set after `cargo install agent-code`.
# Example: C:\Users\pc\.cargo\bin\agent.exe
AGENT_CODE_BIN=

# agent-code uses its own env vars (NOT OPENAI_*). The backend injects these
# when spawning `agent.exe` as a subprocess.
AGENT_CODE_API_BASE_URL=https://router.huggingface.co/v1
AGENT_CODE_API_KEY=hf_your_token_here
AGENT_CODE_MODEL=Qwen/Qwen3-VL-8B-Instruct
